#-----------------------------------------------------------------------
#---------------------------------------------
# Job Specification 
#---------------------------------------------
job = "Diagonalization" 
mode = "NEW" # ("NEW"/"APPEND")
print_level = -2 #-2
prefix="./"
#---------------------------------------------
# Lattice:
#---------------------------------------------
lattice = "HONEYCOMB" 
lsize1 = 10
lsize2 = 10
bc1 = "open"
bc2 = "open"

#---------------------------------------------
# Model:
#---------------------------------------------
model = "KM"
t = 1.0
lambda = 0.1

#---------------------------------------------
# List of observable to calculate:
#---------------------------------------------
BandStruct = "YES"
spin_sector = "BOTH"
kpath = "FULL" # "FULL" # "SYMM"
WaveFunction = "NO" 
qn_list = "[(45,50,0),(45,51,0),(2,8,1),(2,10,1)]" # [(k,n,sigma)]
as_func_of = "t"
#band_gap = "YES"
#chern_number = "YES"

