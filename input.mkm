#----------------------------------------------------------------------
#                       ~~~My program~~~                           
#                       Input Parameters                             
#-----------------------------------------------------------------------
#---------------------------------------------
# Job Specification 
#---------------------------------------------
job = "Diagonalization" 
mode = "NEW" # ("NEW"/"APPEND")
print_level = -2 #-2
prefix="./"
#---------------------------------------------
# Lattice:
#---------------------------------------------
lattice = "HONEYCOMB3" 
lsize1 = 10
lsize2 = 10
bc1 = "open"
bc2 = "open"

#---------------------------------------------
# Model:
#---------------------------------------------
model = "MKM"
t = 1.0
eta = 0.1
lambda = 0.06
lambda_R = 0.0

# Parameters: (eta, lambda_R):
# (1.0,0); (0.5,0); (0.25,0); (0.25,0.84); (0.6,0.84); (0.6,0.36)

#---------------------------------------------
# List of observable to calculate:
#---------------------------------------------
BandStruct = "YES"
spin_sector = "UP"
kpath = "FULL" # "FULL" # "SYMM"
WaveFunction = "NO" 
#qn_list = "[(45,98,0),(45,99,0),(45,100,0),(45,101,0),(55,98,0),(55,99,0),(55,100,0),(55,101,0)]" # [(k,n,sigma)]
qn_list = "[(0,98,0),(0,99,0)]" # [(k,n,sigma)]
as_func_of = "eta"
EEntropy = "YES"
