#----------------------------------------------------------------------
#                       ~~~My program~~~                           
#                       Input Parameters                             
#-----------------------------------------------------------------------
#---------------------------------------------
# Job Specification 
#---------------------------------------------
job = "Diagonalization" 
mode = "NEW" # ("NEW"/"APPEND")
print_level = -2 #-2
prefix="./"
#---------------------------------------------
# Lattice:
#---------------------------------------------
lattice = "HONEYCOMB2" 
lsize1 = 50
lsize2 = 100
bc1 = "open"
bc2 = "periodic"

#---------------------------------------------
# Model:
#---------------------------------------------
model = "MKM"
t = 1.0
eta = 0.60
lambda = 0.06
lambda_R = 0.36

# Parameters: (eta, lambda_R):
# (1.0,0); (0.5,0); (0.25,0); (0.25,0.84); (0.6,0.84); (0.6,0.36)

#---------------------------------------------
# List of observable to calculate:
#---------------------------------------------
BandStruct = "YES"
spin_sector = "UP"
kpath = "FULL" # "FULL" # "SYMM"
WaveFunction = "YES" 
qn_list = "[(40,98,0),(40,99,0),(40,100,0),(40,101,0),(49,98,0),(49,99,0),(49,100,0),(49,101,0)]" # [(k,n,sigma)]
as_func_of = "eta"
#band_gap = "YES"
#chern_number = "YES"
